{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NewsDesk",
  "version": "0.1.1",
  "identifier": "com.newsdesk.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "NewsDesk",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:8000; img-src 'self' http: https: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "externalBin": [
      "sidecars/newsdesk-backend"
    ]
  }
}
